    "\n",
    "    results[system_type][\"eval_score_LLM_judge_int\"] = (\n",
    "        results[system_type][\"eval_score_LLM_judge\"].fillna(\n",
    "            DEFAULT_SCORE).apply(fill_score))\n",
    "    results[system_type][\"eval_score_LLM_judge_int\"] = (\n",
